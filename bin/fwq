#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_DIR="$(dirname "$SCRIPT_DIR")"
SQL_DIR="$BASE_DIR/queries"

[[ -f "$BASE_DIR/config.env" ]] && source "$BASE_DIR/config.env"

DB_HOST="${DB_HOST:-localhost}"
DB_PORT="${DB_PORT:-5432}"
DB_NAME="${DB_NAME:-logdb}"
DB_USER="${DB_USER:-loguser}"

PSQL=(psql -h "$DB_HOST" -p "$DB_PORT" -U "$DB_USER" -d "$DB_NAME" -v ON_ERROR_STOP=1)

usage() {
    echo "Usage:"
    echo "  fwq <query-name>"
    echo "  fwq ports-by-source <ip-or-subnet>"
    echo
    echo "Available queries:"
    find "$SQL_DIR" -maxdepth 1 -type f -name '*.sql' \
        -printf '  %f\n' | sed 's/\.sql$//' | sort
}

[[ $# -ge 1 ]] || {
    usage
    exit 1
}

query="$1"
sql_file="$SQL_DIR/$query.sql"

[[ -f "$sql_file" ]] || {
    echo "Unknown query: $query" >&2
    echo >&2
    usage >&2
    exit 1
}

case "$query" in
    ports-by-source)
        [[ $# -ge 2 ]] || {
            echo "Missing argument." >&2
            echo "Usage: fwq ports-by-source <ip-or-subnet>" >&2
            exit 1
        }

        "${PSQL[@]}" \
            -v subnet="$2" \
            -f "$sql_file"
        ;;

    *)
        if [[ $# -gt 1 ]]; then
            echo "Query '$query' does not accept arguments." >&2
            exit 1
        fi

        "${PSQL[@]}" -f "$sql_file"
        ;;
esac
